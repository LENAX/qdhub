# Dev: Go + Air for hot reload (used by docker-compose.override)
# Use Debian/glibc base image to match DuckDB libduckdb.a
FROM golang:1.24

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Pin air to v1.60.0 (go 1.23); v1.64+ requires go 1.25
RUN go install github.com/air-verse/air@v1.60.0

WORKDIR /app
# Dependencies only; source mounted at runtime
COPY go.mod go.sum ./
RUN go mod download

EXPOSE 8080
CMD ["air", "-c", ".air.toml"]
