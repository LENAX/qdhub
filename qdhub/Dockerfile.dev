# Dev: Go + Air for hot reload (used by docker-compose.override)
FROM golang:1.24-alpine
RUN apk add --no-cache gcc musl-dev
RUN go install github.com/air-verse/air@latest
WORKDIR /app
# Dependencies only; source mounted at runtime
COPY go.mod go.sum ./
RUN go mod download
EXPOSE 8080
CMD ["air", "-c", ".air.toml"]
